{
  "expo": {
    "name": "Armenian Learning",
    "slug": "armenian-learning",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/nora.png",
    "userInterfaceStyle": "light",
    "description": "Learn Armenian with interactive lessons and exercises. Supports English and Persian speakers.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f4ec"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.armenianlearning.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.armenianlearning.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/nora.png"
    },
    "plugins": [
      "expo-font",
      "expo-sqlite"
    ]
  }
}
